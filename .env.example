# --- Core ---
ANTHROPIC_API_KEY=sk-ant-...
# Also accepts deepseek-chat / deepseek-reasoner (see DeepSeek section below).
ADAPTIVE_LEARNING_MODEL=claude-sonnet-4-6
ADAPTIVE_LEARNING_STORE_DIR=./data/store
# Iteration cap on the agent loop (src/harness/limits.py)
ADAPTIVE_LEARNING_MAX_STEPS=10

# Extraction-only model override (graph extraction is one-time, cached):
# ADAPTIVE_LEARNING_EXTRACT_MODEL=deepseek-chat

# --- DeepSeek experiment (optional) ---
# Set ADAPTIVE_LEARNING_MODEL=deepseek-reasoner (or deepseek-chat) and provide:
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Demo gate (Phase 7) ---
# If set, session endpoints require this token via the X-Demo-Token header.
# Leave empty for open local dev. /health and /visual stay open regardless.
DEMO_TOKEN=

# --- Budget caps (Phase 7) ---
# Per-session USD cap — a session that crosses it terminates gracefully.
DEMO_SESSION_USD_CAP=1.00
# Daily global USD cap — session endpoints return "budget exhausted" when crossed.
# Persisted to $ADAPTIVE_LEARNING_STORE_DIR/daily_spend.json (survives restarts).
DEMO_DAILY_USD_CAP=20.00
# Per-IP new-session rate limit (sliding 1-hour window).
DEMO_RATE_LIMIT_PER_HOUR=5

# --- LangSmith tracing (optional, config-only) ---
# Set LANGSMITH_TRACING=true and LANGSMITH_API_KEY to enable. No code change needed.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=adaptive-learning-agent
